# Ollama server URL. Used by both bare-metal (`uv run app.py` /
# `uv run main.py`) and — as a fallback — by the docker compose stack
# if you don't override it via environment.
#
# Bare metal, Ollama on the same machine:
OLLAMA_HOST=http://127.0.0.1:11434
#
# Docker mode (ziggie): the compose file defaults to
#   OLLAMA_HOST=http://ollama:11434
# which resolves via ziggie-net container DNS to the Ollama service.
# You don't need this .env file for docker; it's here for bare-metal
# dev and as a runtime reference.
